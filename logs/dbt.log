    create  table
      "coffee_shop"."main"."fct_product_sales__dbt_tmp"
  
    as (
      

with transactions as (
    select
        product_id,
        product_category,
        product_type,
        transaction_year,
        transaction_month,
        transaction_date,
        transaction_qty,
