        round(avg(gross_revenue), 2)            as avg_transaction_value,
        max(gross_revenue)                      as max_single_transaction

    from transactions
    group by
        product_id,
        product_category,
        product_type,
        transaction_year,
        transaction_month
)

select * from monthly_product
    );
  
  
  
