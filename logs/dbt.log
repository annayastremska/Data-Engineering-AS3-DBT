        count(case when role = 'Cashier'    then 1 end) as cashier_count,

        -- average tenure
        round(avg(tenure_years), 1)                 as avg_tenure_years

    from employees
    group by store_id, store_name, city, region
)

select * from store_summary
    );
  
  
