    create temporary table
      "fct_daily_revenue__dbt_tmp20260318121511231763"
  
    as (
      

with transactions as (
    select
        transaction_date,
        transaction_month,
        transaction_year,
        store_id,
        store_location,
        transaction_qty,
        gross_revenue
    from "coffee_shop"."main"."stg_coffee_shop_transactions"
    
    
        where transaction_date > (
            select max(transaction_date) from "coffee_shop"."main"."fct_daily_revenue"
        )
    

),

daily as (
    select
        store_id,
        store_location,
        transaction_date,
        transaction_year,
        transaction_month,

        count(*)                         as transaction_count,
