        sum(transaction_qty)             as total_units_sold,
        sum(gross_revenue)               as total_revenue,
        round(avg(gross_revenue), 2)     as avg_transaction_value

    from transactions
    group by
        store_id,
        store_location,
        transaction_date,
        transaction_year,
        transaction_month
)

select * from daily
    );
  
  
  
